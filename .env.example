# Скопируйте этот файл в .env и заполните значениями
BOT_TOKEN=ВАШ_НОВЫЙ_ТОКЕН_ОТ_BOTFATHER
OPENROUTER_API_KEY=ВАШ_НОВЫЙ_КЛЮЧ_OPENROUTER
LLM_MODEL=openai/gpt-4o-mini

# LLM_PROVIDER=openrouter | ollama | anthropic | ionet
# OpenRouter (по умолчанию):
# LLM_PROVIDER=openrouter

# Локально Ollama:
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Claude (официальный Anthropic API, Messages API — не устаревший /v1/complete):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Опционально при сбое Claude — ответ через локальную Ollama:
# LLM_FALLBACK_OLLAMA=1

# io.net (IO Intelligence, OpenAI-compatible):
# LLM_PROVIDER=ionet
# IONET_API_KEY=ваш_ключ_с_ai.io.net
# IONET_BASE_URL=https://api.intelligence.io.solutions/api/v1
# IONET_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Telegram-канал для уведомлений о заявках:
NOTIFY_CHANNEL_ID=-100XXXXXXXXXX

# Telegram ID админов для /admin (через запятую):
ADMIN_IDS=123456789,987654321
